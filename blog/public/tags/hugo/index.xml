<td class="lntd">
<pre tabindex="0" class="chroma"><code class="language-fallback" data-lang="fallback"><span class="line"><span class="cl"># create HUGO site called &#34;blog&#34;
</span></span><span class="line"><span class="cl"># choose format yaml
</span></span><span class="line"><span class="cl">hugo new site blog --format yaml
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl"># add theme as submodule
</span></span><span class="line"><span class="cl">git submodule add https://github.com/reorx/hugo-PaperModX.git themes/PaperModX
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl"># update submodule
</span></span><span class="line"><span class="cl">git submodule update --init --recursive
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl"># go to respective site
</span></span><span class="line"><span class="cl">cd blog
</span></span><span class="line"><span class="cl">hugo # to build
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl"># live rebuild server
</span></span><span class="line"><span class="cl">hugo server -D
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl"># before deploy
</span></span><span class="line"><span class="cl">hugo --minify
</span></span></code></pre></td></tr></table>
